# =============================================================================
# FIFA World Cup Intelligence Dashboard — Environment Variables
# =============================================================================
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
#
# The backend validates these on startup via pydantic-settings: a missing
# REQUIRED variable must cause an immediate, clear startup error — not a
# runtime KeyError later (CLAUDE.md §10).
#
# Source of truth for this file: CLAUDE.md §10 and docs/api-research.md §10.
# Secrets (API keys, INGEST_SECRET) are never logged and never returned in any
# API response (CLAUDE.md §11).
# =============================================================================

# --- Database ----------------------------------------------------------------
# Async SQLAlchemy engine (asyncpg driver). In production this is a managed
# Postgres instance; locally it is the Postgres service in docker-compose.yml.
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/worldcup

# --- Football API (Primary: ESPN public — NO key required) -------------------
# ESPN's public JSON API needs no auth; these vars are URL configuration only.
# IMPORTANT: the standings base path is `apis/v2/...`, NOT `apis/site/v2/...`.
# They are different paths — a 200 from the wrong path returns `{}`
# (docs/api-research.md §2).
ESPN_API_BASE_URL=https://site.api.espn.com/apis/site/v2/sports/soccer/fifa.world
ESPN_STANDINGS_URL=https://site.api.espn.com/apis/v2/sports/soccer/fifa.world
ESPN_TIMEOUT_SECONDS=10
ESPN_MAX_RETRIES=2

# --- Football API (Secondary: football-data.org v4) --------------------------
# Register free at https://www.football-data.org/client/register — the key is
# emailed immediately. Free tier: 10 requests/minute (hard limit). World Cup
# competition code: WC (docs/api-research.md §3).
FOOTBALL_DATA_API_KEY=your_key_here
FOOTBALL_DATA_BASE_URL=https://api.football-data.org/v4
FOOTBALL_DATA_TIMEOUT_SECONDS=10
FOOTBALL_DATA_MAX_RETRIES=1

# --- Canonical fixture seed (openfootball — NO key) --------------------------
# Used once by scripts/seed.py to populate teams + fixtures before the first
# ingestion run (docs/api-research.md §4).
OPENFOOTBALL_WORLDCUP_URL=https://raw.githubusercontent.com/openfootball/worldcup.json/master/2026/worldcup.json

# --- AI ----------------------------------------------------------------------
# Multi-provider: set the provider, its model id, and the key for that ONE
# provider — switching providers means changing these three values, nothing else.
# Free-tier-friendly defaults first (groq). Every AI call logs: model, input
# tokens, output tokens, latency, cache hit/miss (CLAUDE.md §4.6, §8).
#
#   groq        → e.g. llama-3.3-70b-versatile        (free tier, fast)
#   gemini      → e.g. gemini-2.0-flash               (free tier)
#   openrouter  → e.g. meta-llama/llama-3.3-70b-instruct:free
#   anthropic   → e.g. claude-haiku-4-5
#   openai      → e.g. gpt-4o-mini
AI_PROVIDER=groq                       # groq | gemini | openrouter | anthropic | openai
AI_MODEL=llama-3.3-70b-versatile       # model id at the chosen provider
AI_API_KEY=your_key_here               # key for the ACTIVE provider
AI_MAX_TOKENS=300                      # set intentionally — never the model default
AI_DAILY_BUDGET_USD=2.00               # circuit breaker: stop generating above this

# --- Ingestion ---------------------------------------------------------------
INGEST_SECRET=a_long_random_string     # required header on POST /ingest (401 if absent/wrong)
SCHEDULER_ENABLED=true                 # false in tests/scripts: app import never fires HTTP
INGEST_INTERVAL_SECONDS=60             # scheduler cadence outside live windows
LIVE_POLL_INTERVAL_SECONDS=30          # faster cadence while a match is live
RECONCILIATION_SCORE_MISMATCH_ALERT_AFTER=3   # runs before a CRITICAL log fires
FRESHNESS_THRESHOLD_MINUTES=5          # staleness threshold during live windows

# --- App ---------------------------------------------------------------------
ENVIRONMENT=development                # development | production
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000     # comma-separated in production; NEVER `*`
