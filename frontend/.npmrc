# @vercel/analytics declares an OPTIONAL peer on @sveltejs/kit (which pulls
# vite@8), conflicting with the vite@7 our vitest toolchain uses. We don't use
# Svelte, so this peer is irrelevant — accept the resolution instead of letting
# npm's strict peer check fail the install (locally and on Vercel). Same class of
# dev-toolchain peer fragility as KL-015.
legacy-peer-deps=true
